# Database (defaults to local SQLite; point at Postgres to swap)
DATABASE_URL=sqlite:///./app.db

# Local file storage directory (swap storage.py for S3 in production)
UPLOAD_DIR=./uploads

# Slide 19 AI image generation (pluggable). Leave unset to disable
# generation entirely -- the UI will fall back to manual upload.
IMAGE_GEN_PROVIDER=openai
IMAGE_GEN_API_KEY=
IMAGE_GEN_API_BASE=https://api.openai.com/v1
IMAGE_GEN_MODEL=gpt-image-1
